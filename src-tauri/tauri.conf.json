{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ghost",
  "version": "0.1.0",
  "identifier": "com.ghosted.messenger",
  "build": {
    "frontendDist": "dist/public-messenger",
    "devUrl": "http://localhost:5000",
    "beforeDevCommand": "cross-env VITE_APP_MODE=messenger APP_MODE=messenger tsx server/index.ts",
    "beforeBuildCommand": "npm run build:messenger && npm run build:server"
  },
  "app": {
    "windows": [
      {
        "title": "Ghost",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
