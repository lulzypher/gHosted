# Copy to `.env` and adjust.

# alt.dream gateway (Ghost messenger uses this — not gHosted Postgres APIs)
# Local dev with `npm run dev`: leave unset; Vite proxies http://localhost:5000/gw → gateway :8787
# VITE_GATEWAY_URL=http://127.0.0.1:8787

# Legacy full-app server (only needed for dev:altdream or old /api routes)
# DATABASE_URL=postgresql://localhost:5432/ghosted
# SESSION_SECRET=dev-change-me

# Optional IPFS overrides (client)
# VITE_IPFS_GATEWAY=https://ipfs.io
