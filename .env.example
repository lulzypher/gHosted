# Copy to `.env` and adjust. Required for Ghost auth + messaging (Postgres session store).
DATABASE_URL=postgresql://localhost:5432/ghosted

# Dev default is fine; set a long random string in production.
SESSION_SECRET=dev-change-me

# Optional: local HTTP (e.g. Docker) without HTTPS cookies
# ALLOW_HTTP_SESSION_COOKIES=true

# Optional IPFS overrides (client)
# VITE_IPFS_GATEWAY=https://ipfs.io
